alias fedi="neonmodem"
alias fzfn="fzf | xargs nvim"
# Cross-platform clipboard copy
clipcopy() {
  if command -v pbcopy &> /dev/null; then
    pbcopy
  elif command -v wl-copy &> /dev/null; then
    wl-copy
  elif command -v xclip &> /dev/null; then
    xclip -selection clipboard
  else
    echo "No clipboard tool found (pbcopy/xclip/wl-copy)"
    return 1
  fi
}
alias ro="cd $HOME/repos/open"
alias rp="cd $HOME/repos/personal"
alias rw="cd $HOME/repos/work"
alias so="source $ZDOTDIR/.zshrc"
alias tms="sh $HOME/.config/zsh/scripts/shell/session-wizard.sh"
alias vim="nvim"

# Ensure vim alias uses proper completion
if (( $+functions[compdef] )); then
  compdef vim=nvim
fi
alias yc="gpg-connect-agent 'scd serialno' 'learn --force' /bye"

if command -v bat &> /dev/null; then
  alias view="bat"
fi

# Change directory with fzf (renamed from fc to avoid conflict)
cdf() {
  local dir
  dir=$(command find ${1:-.} -type d -not -path '*/\.*' 2> /dev/null | fzf +m) && cd "$dir"
}
